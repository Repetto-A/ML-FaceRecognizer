# Copiar a `.env` en la raíz del proyecto (NUNCA commitear el .env real).
# El servicio NO arranca si API_KEY está vacío.

API_KEY=cambiame-por-una-clave-larga-y-aleatoria
ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=10
INDEX_DIR=./index
DEFAULT_THRESHOLD=0.65
TORCH_DEVICE=cpu
UPLOAD_DIR=./uploads
SEARCH_RATE_LIMIT=30/minute
REGISTER_RATE_LIMIT=10/minute
